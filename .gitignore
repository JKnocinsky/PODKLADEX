##################################################
# .gitignore for C# / .NET / Windows Forms / EF
##################################################

# =========================
# Visual Studio - local/user files
# =========================
.vs/
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Rider / ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# VS Code local settings
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# =========================
# Build outputs
# =========================
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
[Oo]ut/

# Logs and temp files
*.log
*.tmp
*.temp
*.cache
*.pidb
*.svclog

# =========================
# Test / coverage artifacts
# =========================
[Tt]est[Rr]esult*/
*.trx
*.coverage
*.coveragexml
coverage*.json
coverage*.xml
coverage*.info
BenchmarkDotNet.Artifacts/

# =========================
# NuGet / packages
# =========================
packages/
*.nupkg
*.snupkg

# =========================
# Database local files
# =========================
*.mdf
*.ldf
*.ndf

# =========================
# Publish / deployment outputs
# =========================
publish/
*.publish.xml
*.pubxml
*.publishproj

# =========================
# Generated / designer / cache leftovers
# =========================
Generated\ Files/
ipch/
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.VC.db
*.VC.VC.opendb

# =========================
# Optional environment files
# =========================
.env
.env.*

# =========================
# Do NOT ignore:
# - source code files (*.cs)
# - solution / project files (*.sln, *.csproj)
# - Entity Framework migrations
# - SQL scripts (*.sql, DML, DQL)
# - manually added required libraries, if kept intentionally
# =========================
